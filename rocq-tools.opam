# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
synopsis: "AI-native MCP tool layer for the Rocq prover"
description:
  "An empirically-designed, policy-neutral MCP (Model Context Protocol) server that lets LLM agents drive the Rocq prover: persistent in-process sessions, speculative tactic evaluation, a finisher portfolio with hint synthesis, enriched errors, project load-path auto-discovery, and multi-agent shared-proof support."
maintainer: ["guillaume.baudart@gmail.com"]
authors: ["LLM4Rocq"]
license: "MIT"
homepage: "https://github.com/LLM4Rocq/rocq-tools"
bug-reports: "https://github.com/LLM4Rocq/rocq-tools/issues"
depopts: [
  "coq-mathcomp-zify"
  "coq-mathcomp-algebra-tactics"
]
depends: [
  "ocaml" {>= "4.14"}
  "dune" {>= "3.23"}
  "rocq-runtime" {>= "9.1" & < "9.2"}
  "memprof-limits"
  "rocq-stdlib"
  "yojson"
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/LLM4Rocq/rocq-tools.git"
x-maintenance-intent: ["(latest)"]
